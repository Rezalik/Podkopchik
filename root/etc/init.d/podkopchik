#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

APP="podkopchik"
CTL="/usr/bin/podkopchikctl"
HEALTH="/usr/libexec/podkopchik/health_check.sh"
RULES="/usr/libexec/podkopchik/apply_rules.sh"
CLEANUP="/usr/libexec/podkopchik/cleanup_rules.sh"
CONFIG="/etc/podkopchik/config.json"

xray_bin() {
	command -v xray 2>/dev/null || command -v xray-core 2>/dev/null || true
}

uci_bool() {
	[ "$(uci -q get "$1" 2>/dev/null)" = "1" ]
}

start_service() {
	uci_bool "$APP.main.enabled" || return 0

	mkdir -p /tmp/podkopchik /etc/podkopchik

	procd_open_instance health
	procd_set_param command "$HEALTH" daemon
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance

	if uci_bool "$APP.main.routing_enabled" && [ -s "$CONFIG" ]; then
		if "$CTL" validate-active >/dev/null 2>&1; then
			"$RULES" >/dev/null 2>&1 || logger -t podkopchik "failed to apply Podkopchik nftables rules"
			bin="$(xray_bin)"
			if [ -n "$bin" ]; then
				procd_open_instance xray
				procd_set_param command "$bin" run -config "$CONFIG"
				procd_set_param respawn 3600 5 5
				procd_set_param stdout 1
				procd_set_param stderr 1
				procd_close_instance
			else
				logger -t podkopchik "xray binary not found; routing remains inactive"
				"$CLEANUP" >/dev/null 2>&1 || true
			fi
		else
			logger -t podkopchik "active Xray config failed validation; keeping routing inactive"
			"$CLEANUP" >/dev/null 2>&1 || true
		fi
	fi
}

stop_service() {
	"$CLEANUP" >/dev/null 2>&1 || true
}

reload_service() {
	restart
}

service_triggers() {
	procd_add_reload_trigger "$APP"
}
